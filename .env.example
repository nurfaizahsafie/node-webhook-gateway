PORT=3000

# Postgres - event log
DATABASE_URL=postgresql://webhook:webhook@localhost:5434/webhook_gateway

# Redis - reused from the PHP Payment Gateway Simulator's instance (port 6380)
# so both services share the same event-dedup + delivery-tracking cache.
REDIS_URL=redis://localhost:6380

# Must match the signing secret issued when registering a webhook endpoint
# via the PHP Gateway's POST /api/webhooks/endpoints
WEBHOOK_SIGNING_SECRET=change-me-to-a-long-random-string

# Retry behaviour for outbound merchant delivery
MAX_DELIVERY_ATTEMPTS=5
RETRY_BASE_DELAY_MS=2000
